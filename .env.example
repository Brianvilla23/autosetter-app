# ─────────────────────────────────────────────────────────────
# DMCloser — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# En producción, configúralos en Railway → Variables.
# ─────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Meta / Instagram API ─────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=mi_token_secreto_webhook
META_ACCESS_TOKEN=

# ── App ──────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=cambiar_esto_en_produccion
JWT_SECRET=cambiar_esto_en_produccion

# ── Lemon Squeezy (USD · Internacional) ──────────────────────
# Settings → API → Create API Key
LS_API_KEY=
# Settings → Stores → tu store ID
LS_STORE_ID=
# Settings → Webhooks → signing secret
LS_WEBHOOK_SECRET=
# Products → crea 3 productos con variante suscripción mensual
# y copia el variant_id de cada uno:
LS_VARIANT_STARTER=
LS_VARIANT_PRO=
LS_VARIANT_AGENCY=

# ── Mercado Pago (CLP · Chile) ───────────────────────────────
# Devs → Tus credenciales (cuenta Chile) → Access token de producción
MP_ACCESS_TOKEN=
# Crea 3 preapproval plans vía API o dashboard y pega los IDs:
MP_PLAN_STARTER=
MP_PLAN_PRO=
MP_PLAN_AGENCY=
# Precios en CLP (opcional — defaults ya en código)
MP_PRICE_STARTER_CLP=180000
MP_PRICE_PRO_CLP=270000
MP_PRICE_AGENCY_CLP=450000
